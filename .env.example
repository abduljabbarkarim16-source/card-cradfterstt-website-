# Environment Variables

# Add these to your .env.local file for development

# Payment Gateway (when ready)
# NEXT_PUBLIC_STRIPE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Email Service (when ready)
# RESEND_API_KEY=re_...

# Google Analytics (when ready)
# NEXT_PUBLIC_GA_ID=G_...

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Card Crafters

# Contact Email (for form submissions)
CONTACT_EMAIL=support@cardcrafters.com
